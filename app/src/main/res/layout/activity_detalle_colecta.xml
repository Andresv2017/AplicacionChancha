<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="Detalle de colecta"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Card con QR e info de la colecta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tvTituloColecta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimaryDark"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvMontoDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/gray_text"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvFechaLimiteDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/gray_text"
                        android:visibility="gone"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tvEstadoDetalle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Código QR -->
                    <ImageView
                        android:id="@+id/ivQrCode"
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:contentDescription="Código QR"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comparte este QR para pagar"
                        android:textSize="12sp"
                        android:textColor="@color/gray_text"
                        android:layout_marginBottom="16dp"/>

                    <!-- Botón Pagar (solo visible si mi estado = pendiente) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPagar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Registrar mi pago"
                        android:backgroundTint="@color/colorAccent"
                        android:textColor="@color/white"
                        android:visibility="gone"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Título sección pagos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Estado de pagos"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimaryDark"/>

            <!-- Lista de pagos -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPagos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
